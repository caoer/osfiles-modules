{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#a9b1d6",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "#565f89",
    "italic": true
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#7aa2f7",
    "bold": true
  },
  "h1": {
    "prefix": "# ",
    "color": "#bb9af7",
    "bold": true,
    "background_color": "#24283b"
  },
  "h2": {
    "prefix": "## ",
    "color": "#7aa2f7",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "#7dcfff",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "#73daca",
    "bold": true
  },
  "h5": {
    "prefix": "##### ",
    "color": "#b4f9f8",
    "bold": true
  },
  "h6": {
    "prefix": "###### ",
    "color": "#c0caf5",
    "bold": true
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true,
    "color": "#bb9af7"
  },
  "strong": {
    "bold": true,
    "color": "#e0af68"
  },
  "hr": {
    "color": "#3b4261",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#7aa2f7",
    "underline": true
  },
  "link_text": {
    "color": "#73daca",
    "bold": true
  },
  "image": {
    "color": "#7aa2f7",
    "underline": true
  },
  "image_text": {
    "color": "#e0af68",
    "format": "Image: {{.text}}"
  },
  "code": {
    "color": "#9ece6a",
    "background_color": "#1a1b26"
  },
  "code_block": {
    "color": "#a9b1d6",
    "background_color": "#1a1b26",
    "margin": 2,
    "chroma": {
      "theme": "tokyonight-night"
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {
    "color": "#7aa2f7",
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n"
  },
  "html_block": {},
  "html_span": {}
}
